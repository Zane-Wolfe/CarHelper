# --- OBD-II Bluetooth adapter (Vgate vLinker MC+, Classic SPP) ---
# MAC address of the dongle. Leave blank to auto-detect by name during Connect.
# Find it with:  bluetoothctl  ->  scan on  (look for the vLinker)
OBD_BT_MAC=
# Advertised device name to match when OBD_BT_MAC is blank.
OBD_BT_NAME=vLinker MC-Android
# Classic SPP pairing PIN for the vLinker MC+.
OBD_BT_PIN=1234

# --- Capture ---
# Live polling rate in Hz.
SAMPLE_HZ=2

# --- Simulation ---
# 1 = run with a synthetic OBD source (no car or dongle needed). 0 = real adapter.
SIMULATE=0

# --- Web server ---
HOST=0.0.0.0
PORT=8000

# --- Storage (inside the container; mounted to host ./data) ---
DATA_DIR=/app/data
